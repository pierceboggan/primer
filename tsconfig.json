{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "declaration": true,
    "resolveJsonModule": true,
    "types": ["node", "react"],
    "paths": {
      "@agentrc/core": ["./packages/core/src/index.ts"],
      "@agentrc/core/*": ["./packages/core/src/*"]
    }
  },
  "include": ["src", "packages/core/src"]
}
