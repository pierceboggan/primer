{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "paths": {
      "@agentrc/core": ["../packages/core/src/index.ts"],
      "@agentrc/core/*": ["../packages/core/src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "out"]
}
